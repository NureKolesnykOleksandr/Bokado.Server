    {
      "name": "0. Setup",
      "item": [
        {
          "name": "Register Target User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('targetUserEmail', pm.variables.replaceIn('{{$randomEmail}}'));",
                  "pm.collectionVariables.set('targetUserName',  pm.variables.replaceIn('{{$randomUserName}}'));"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 2xx\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]); });",
                  "var json = pm.response.json();",
                  "if (json.user && json.user.userId)",
                  "  pm.collectionVariables.set('targetUserId', String(json.user.userId));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{targetUserName}}\",\n  \"email\": \"{{targetUserEmail}}\",\n  \"password\": \"Test1234!\",\n  \"birthDate\": \"2000-01-01T00:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 2xx\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]); });",
                  "var json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
